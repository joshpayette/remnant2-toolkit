{
  "name": "remnant2-toolkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "lint-fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:push:force": "dotenv -e .env.local -- prisma db push --force-reset",
    "db:studio": "dotenv -e .env.local -- pnpm dlx prisma studio",
    "db:local:start": "docker compose -f compose.local.yaml up -d",
    "db:local:stop": "docker compose -f compose.local.yaml stop",
    "db:local:restart": "docker compose -f compose.local.yaml restart",
    "db:local:down": "docker compose -f compose.local.yaml down -v"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.1",
    "@fortawesome/fontawesome-svg-core": "^6.6.0",
    "@fortawesome/free-brands-svg-icons": "^6.6.0",
    "@fortawesome/free-regular-svg-icons": "^6.6.0",
    "@fortawesome/free-solid-svg-icons": "^6.6.0",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "@headlessui/react": "2.2.9",
    "@mdx-js/loader": "3.0.0",
    "@mdx-js/react": "3.0.0",
    "@next/mdx": "16.1.6",
    "@popperjs/core": "2.11.8",
    "@prisma/adapter-mariadb": "^7.4.0",
    "@prisma/adapter-planetscale": "^7.4.0",
    "@prisma/client": "7.3.0",
    "@reduxjs/toolkit": "2.2.2",
    "@vercel/analytics": "1.1.1",
    "@vercel/flags": "^2.6.0",
    "cheerio": "1.0.0-rc.12",
    "clipboard-copy": "4.0.1",
    "clsx": "2.1.1",
    "date-fns": "3.3.1",
    "diff": "5.2.0",
    "dotenv": "17.2.3",
    "framer-motion": "11.3.2",
    "he": "^1.2.0",
    "html2canvas": "1.4.1",
    "imagekit": "5.0.0",
    "lodash.clonedeep": "4.5.0",
    "lodash.isequal": "4.5.0",
    "motion": "^12.34.3",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "0.3.0",
    "nuqs": "2.5.2",
    "papaparse": "5.4.1",
    "patreon": "0.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-popper": "2.3.0",
    "react-select": "^5.8.1",
    "react-string-replace": "1.1.1",
    "react-toastify": "9.1.3",
    "sharp": "0.33.2",
    "swr": "^2.2.5",
    "tailwind-merge": "2.0.0",
    "usehooks-ts": "2.14.0",
    "uuid": "9.0.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3",
    "@next/eslint-plugin-next": "16.0.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/diff": "5.0.9",
    "@types/he": "^1.2.3",
    "@types/lodash.clonedeep": "4.5.9",
    "@types/lodash.isequal": "4.5.8",
    "@types/mdx": "2.0.10",
    "@types/node": "20",
    "@types/papaparse": "5.3.14",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "9.0.8",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "10.4.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "10.0.0",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "node-xlsx": "0.23.0",
    "postcss": "8.5.6",
    "prettier": "3.5.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.3.0",
    "tailwindcss": "4.2.0",
    "ts-node": "10.9.1",
    "typescript": "5",
    "typescript-eslint": "8.46.2",
    "vite-tsconfig-paths": "5.1.4"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
